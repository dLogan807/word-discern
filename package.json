{
  "name": "word-discern",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "npm run oxlint && npm run stylelint",
    "oxlint": "oxlint .",
    "stylelint": "stylelint \"**/*.css\" --cache",
    "format:test": "oxfmt --check \"**/*.{ts,tsx,css}\"",
    "format:write": "oxfmt --write \"**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@mantine/core": "^9.1.1",
    "@mantine/form": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@tabler/icons-react": "^3.35.0",
    "@types/node": "^24.9.2",
    "jsonc-parser": "^3.3.1",
    "oxlint": "^1.71.0",
    "path": "^0.12.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "stylelint": "^17.13.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "baseline-browser-mapping": "^2.10.28",
    "oxfmt": "^0.56.0",
    "postcss": "^8.5.14",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  }
}
